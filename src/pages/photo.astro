---
import "@fontsource/azeret-mono/300.css";
import "@fontsource/azeret-mono/400.css";
import "@fontsource/bebas-neue";
import { getImage } from "astro:assets";
import type { ImageMetadata } from "astro";
import HeroCarousel from "../components/HeroCarousel.astro";
import Lightbox from "../components/Lightbox.astro";
import PhotoGallery from "../components/PhotoGallery.astro";
import Base from "../layouts/Base.astro";

const year = new Date().getFullYear();

const photoModules = import.meta.glob<{ default: ImageMetadata }>(
	"../assets/photos/*.{jpg,jpeg,JPG,JPEG,png,PNG,webp,WEBP}",
	{ eager: true },
);

const allEntries = Object.entries(photoModules).map(([path, m]) => ({
	meta: m.default,
	filename: path.split("/").pop() ?? "",
}));

const stableHash = (value: string): number => {
	let hash = 2166136261;
	for (let i = 0; i < value.length; i++) {
		hash ^= value.charCodeAt(i);
		hash = Math.imul(hash, 16777619);
	}
	return hash >>> 0;
};

const formatImageName = (src: string): string => {
	const fileName = src.split("/").pop() ?? src;
	return fileName
		.replace(/\.[^.]+$/, "")
		.replace(/[._-]+/g, " ")
		.replace(/\s+/g, " ")
		.trim();
};

const galleryEntries = [...allEntries].sort((a, b) => {
	const diff = stableHash(a.filename) - stableHash(b.filename);
	return diff !== 0 ? diff : a.filename.localeCompare(b.filename);
});

const fullResImages = await Promise.all(
	galleryEntries.map((entry) =>
		getImage({ src: entry.meta, width: 1920, format: "webp" }),
	),
);

const lightboxImages = galleryEntries.map((entry, i) => ({
	src: fullResImages[i].src,
	alt: `Live event photo ${String(i + 1).padStart(2, "0")}: ${formatImageName(entry.filename)}`,
}));

const heroImageFiles = [
	"CFU-22.03.2025-1.jpg",
	"0623-GarnixOpenAir-Bands-90.jpg",
	"Luxuspop-22.11.2024-42.jpg",
	"0623-GarnixOpenAir-Bands-93.jpg",
	"Dailysoap-64.jpg",
	"LMU-Sommerfest-15.jpg",
	"TheFinalShow-10.jpg",
	"GARNIX-2022-22-Days-16.JPG",
	"Die-CSD-Party-NY.Club-28.06.2025-105.jpg",
	"SHRX-NEON-MUSIC-FESTIVAL-79.jpg",
];

const heroImages = heroImageFiles
	.map((name) => {
		const entry = allEntries.find((e) => e.filename === name);
		return entry?.meta;
	})
	.filter((img): img is ImageMetadata => img !== undefined);
---

<Base title="Janez Rotman / Photo" description="Event and live music photography in Munich.">

		<nav class="hud">
			<a href="/" class="hud-name">Janez Rotman</a>
			<div class="hud-right">
				<span class="hud-link">janez ÄŦ janez DOT at</span>
				<a href="/" class="hud-link">Home</a>
			</div>
		</nav>

		<div class="stage">
			<HeroCarousel heroImages={heroImages} />
			<PhotoGallery entries={galleryEntries} />
		</div>

		<Lightbox images={lightboxImages} />

		<footer class="foot">
			<div class="foot-left">
				<span class="foot-copy">&copy; {year}</span>
				<span class="foot-loc">Munich</span>
			</div>
			<div class="foot-right">
				<span>Events</span>
				<span class="foot-dot"></span>
				<span>Bands</span>
				<span class="foot-dot"></span>
				<span>Live</span>
			</div>
		</footer>

</Base>

<style>
	* { margin: 0; padding: 0; box-sizing: border-box; }

	body {
		background: #050505;
		color: #888;
		font-family: "Azeret Mono", monospace;
		font-size: 11px;
		font-weight: 300;
		letter-spacing: 0.04em;
		min-height: 100vh;
	}

	/* Red accent glow at top */
	body::before {
		content: "";
		position: fixed;
		top: -200px;
		left: 50%;
		transform: translateX(-50%);
		width: 600px;
		height: 400px;
		background: radial-gradient(ellipse, rgba(200, 30, 20, 0.06) 0%, transparent 70%);
		pointer-events: none;
		z-index: 0;
	}

	/* ---- HUD ---- */
	.hud {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 100;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 20px 28px;
		background: linear-gradient(to bottom, rgba(5,5,5,0.9) 40%, transparent);
	}

	.hud-name {
		color: #e8e4de;
		text-decoration: none;
		text-transform: uppercase;
		font-weight: 400;
		font-size: 10px;
		letter-spacing: 0.18em;
		transition: color 0.3s;
	}

	.hud-name:hover { color: #fff; text-decoration: none; }

	.hud-right {
		display: flex;
		align-items: center;
		gap: 20px;
	}

	.hud-link {
		color: #888;
		text-decoration: none;
		text-transform: uppercase;
		font-size: 10px;
		letter-spacing: 0.12em;
		transition: color 0.3s;
	}

	.hud-link:hover { color: #ccc; text-decoration: none; }

	/* ---- Stage ---- */
	.stage {
		padding: 0 0 80px;
	}

	/* ---- Footer ---- */
	.foot {
		max-width: 1400px;
		margin: 80px auto 0;
		padding: 20px 28px 32px;
		border-top: 1px solid #151515;
		display: flex;
		justify-content: space-between;
		align-items: center;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		font-size: 10px;
	}

	.foot-left {
		display: flex;
		gap: 20px;
		color: #333;
	}

	.foot-right {
		display: flex;
		align-items: center;
		gap: 12px;
		color: #444;
	}

	.foot-dot {
		width: 3px;
		height: 3px;
		border-radius: 50%;
		background: #c8281e;
	}

	@media (max-width: 700px) {
		.foot {
			flex-direction: column;
			gap: 12px;
			align-items: flex-start;
			padding: 20px 12px 28px;
		}
	}
</style>
