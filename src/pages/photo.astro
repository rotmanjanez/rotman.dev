---
import "@fontsource/azeret-mono/300.css";
import "@fontsource/azeret-mono/400.css";
import "@fontsource/bebas-neue";
import { getImage, Image } from "astro:assets";
import type { ImageMetadata } from "astro";
// Photography portfolio -- "The Stage"
// Brutalist type, high-contrast, full-bleed hero with background image.
import Base from "../layouts/Base.astro";

const year = new Date().getFullYear();

const photoModules = import.meta.glob<{ default: ImageMetadata }>(
	"../assets/photos/*.{jpg,jpeg,JPG,JPEG,png,PNG,webp,WEBP}",
	{ eager: true },
);

const allEntries = Object.entries(photoModules).map(([path, m]) => ({
	meta: m.default,
	filename: path.split("/").pop() ?? "",
}));

const stableHash = (value: string): number => {
	let hash = 2166136261;
	for (let i = 0; i < value.length; i++) {
		hash ^= value.charCodeAt(i);
		hash = Math.imul(hash, 16777619);
	}
	return hash >>> 0;
};

const formatImageName = (src: string): string => {
	const fileName = src.split("/").pop() ?? src;
	return fileName
		.replace(/\.[^.]+$/, "")
		.replace(/[._-]+/g, " ")
		.replace(/\s+/g, " ")
		.trim();
};

const galleryEntries = [...allEntries].sort((a, b) => {
	const diff = stableHash(a.filename) - stableHash(b.filename);
	return diff !== 0 ? diff : a.filename.localeCompare(b.filename);
});

// Pre-generate full-res images for the lightbox
const fullResImages = await Promise.all(
	galleryEntries.map((entry) =>
		getImage({ src: entry.meta, width: 1920, format: "webp" }),
	),
);

const HERO_SLOT_DURATION = 6; // seconds per image

const heroImageFiles = [
	"CFU-22.03.2025-1.jpg",
	"0623-GarnixOpenAir-Bands-90.jpg",
	"Luxuspop-22.11.2024-42.jpg",
	"0623-GarnixOpenAir-Bands-93.jpg",
	"Dailysoap-64.jpg",
	"LMU-Sommerfest-15.jpg",
	"TheFinalShow-10.jpg",
	"GARNIX-2022-22-Days-16.JPG",
	"Die-CSD-Party-NY.Club-28.06.2025-105.jpg",
	"SHRX-NEON-MUSIC-FESTIVAL-79.jpg",
];

const heroImages = heroImageFiles
	.map((name) => {
		const entry = allEntries.find((e) => e.filename === name);
		return entry?.meta;
	})
	.filter((img): img is ImageMetadata => img !== undefined);
---

<Base title="Janez Rotman / Photo">

		<div class="progress-bar" aria-hidden="true"></div>

		<nav class="hud">
			<a href="/" class="hud-name">Janez Rotman</a>
			<div class="hud-right">
				<a href="mailto:janez@janez.at" class="hud-link">janez@janez.at</a>
				<a href="/" class="hud-link">Home</a>
			</div>
		</nav>

		<div class="stage">
			<div class="stage-title">
				<div class="hero-bg">
					{heroImages.map((img, i) => (
						<Image src={img} alt="" width={1920} height={1280} loading={i === 0 ? "eager" : "lazy"} class={i === 0 ? "active" : ""} />
					))}
				</div>
				<div class="hero-overlay"></div>
				<div class="vivid-layer">
					{heroImages.map((img, i) => (
						<Image src={img} alt="" width={1920} height={1280} loading={i === 0 ? "eager" : "lazy"} class={i === 0 ? "active" : ""} />
					))}
				</div>
				<h1 class="title-text">Photo</h1>
				<div class="hero-controls" id="hero-controls">
					<button class="hero-btn" id="hero-prev" aria-label="Previous image">
						<svg width="10" height="16" viewBox="0 0 10 16" fill="none"><path d="M8 2 L2 8 L8 14" stroke="currentColor" stroke-width="1.2" /></svg>
					</button>
					<button class="hero-btn" id="hero-pause" aria-label="Pause slideshow">
						<svg class="icon-pause" width="10" height="12" viewBox="0 0 10 12" fill="none"><rect x="1" y="1" width="2.5" height="10" fill="currentColor" /><rect x="6.5" y="1" width="2.5" height="10" fill="currentColor" /></svg>
						<svg class="icon-play" width="10" height="12" viewBox="0 0 10 12" fill="none" style="display:none"><path d="M1 1 L9 6 L1 11Z" fill="currentColor" /></svg>
					</button>
					<button class="hero-btn" id="hero-next" aria-label="Next image">
						<svg width="10" height="16" viewBox="0 0 10 16" fill="none"><path d="M2 2 L8 8 L2 14" stroke="currentColor" stroke-width="1.2" /></svg>
					</button>
				</div>
				<div class="scroll-cue">
					<span class="scroll-cue-text">Scroll</span>
					<div class="scroll-cue-arrow">
						<svg width="14" height="24" viewBox="0 0 14 24" fill="none">
							<path d="M7 0 L7 20 M1 15 L7 22 L13 15" stroke="currentColor" stroke-width="1.5" />
						</svg>
					</div>
				</div>
			</div>

				<div class="gallery">
					{galleryEntries.map((entry, i) => {
						const altText = `Live event photo ${String(i + 1).padStart(2, "0")}: ${formatImageName(entry.filename)}`;
						const num = String(i + 1).padStart(2, "0");

						return (
							<a href={`#photo-${i}`} class="shot" data-index={i}>
								<Image src={entry.meta} alt={altText} width={900} height={Math.round(900 * (entry.meta.height / entry.meta.width))} loading={i < 6 ? "eager" : "lazy"} />
								<div class="shot-num">{num}</div>
							</a>
						);
					})}
				</div>
		</div>

		{galleryEntries.map((entry, i) => {
			const altText = `Live event photo ${String(i + 1).padStart(2, "0")}: ${formatImageName(entry.filename)}`;
			const prev = i > 0 ? `#photo-${i - 1}` : null;
			const next = i < galleryEntries.length - 1 ? `#photo-${i + 1}` : null;

			return (
				<div class="lightbox" id={`photo-${i}`} data-index={i}>
					<a href="#" class="lightbox-bg" aria-label="Close"></a>
					<div class="lightbox-inner">
						{prev && <a href={prev} class="lightbox-nav lightbox-prev" aria-label="Previous">&lsaquo;</a>}
						<img src={fullResImages[i].src} alt={altText} class="lightbox-img" loading="lazy" />
						{next && <a href={next} class="lightbox-nav lightbox-next" aria-label="Next">&rsaquo;</a>}
					</div>
					<a href="#" class="lightbox-close" aria-label="Close">&times;</a>
				</div>
			);
		})}

		<footer class="foot">
			<div class="foot-left">
				<span class="foot-copy">&copy; {year}</span>
				<span class="foot-loc">Munich</span>
			</div>
			<div class="foot-right">
				<span>Events</span>
				<span class="foot-dot"></span>
				<span>Bands</span>
				<span class="foot-dot"></span>
				<span>Live</span>
			</div>
		</footer>

</Base>

<style>
	* { margin: 0; padding: 0; box-sizing: border-box; }

	body {
		background: #050505;
		color: #888;
		font-family: "Azeret Mono", monospace;
		font-size: 11px;
		font-weight: 300;
		letter-spacing: 0.04em;
		min-height: 100vh;
	}

	/* Scroll progress bar */
	.progress-bar {
		position: fixed;
		top: 0;
		left: 0;
		height: 2px;
		width: 0%;
		background: #c8281e;
		z-index: 200;
		transition: width 0.1s linear;
		box-shadow: 0 0 8px rgba(200, 40, 30, 0.6);
	}

	/* Red accent glow at top */
	body::before {
		content: "";
		position: fixed;
		top: -200px;
		left: 50%;
		transform: translateX(-50%);
		width: 600px;
		height: 400px;
		background: radial-gradient(ellipse, rgba(200, 30, 20, 0.06) 0%, transparent 70%);
		pointer-events: none;
		z-index: 0;
	}

	/* ---- HUD ---- */
	.hud {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 100;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 20px 28px;
		background: linear-gradient(to bottom, rgba(5,5,5,0.9) 40%, transparent);
	}

	.hud-name {
		color: #e8e4de;
		text-decoration: none;
		text-transform: uppercase;
		font-weight: 400;
		font-size: 10px;
		letter-spacing: 0.18em;
		transition: color 0.3s;
	}

	.hud-name:hover { color: #fff; text-decoration: none; }

	.hud-right {
		display: flex;
		align-items: center;
		gap: 20px;
	}

	.hud-link {
		color: #888;
		text-decoration: none;
		text-transform: uppercase;
		font-size: 10px;
		letter-spacing: 0.12em;
		transition: color 0.3s;
	}

	.hud-link:hover { color: #ccc; text-decoration: none; }

	/* ---- Stage ---- */
	.stage {
		padding: 0 0 80px;
	}

	.stage-title {
		height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		position: relative;
		overflow: hidden;
	}

	.hero-bg {
		position: absolute;
		inset: 0;
		z-index: 0;
	}

	.hero-bg img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: contrast(1.2) saturate(0.4) brightness(0.9);
		opacity: 0;
		transition: opacity 1s ease;
	}

	.hero-bg img:global(.active) {
		opacity: 1;
	}

	.vivid-layer {
		position: absolute;
		inset: 0;
		z-index: 3;
		overflow: hidden;
		-webkit-mask-image: url("data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' width='100%' height='100%'><text font-family='Bebas Neue,Impact,sans-serif' font-size='22vw' fill='white' x='50%' y='55%' text-anchor='middle' dominant-baseline='middle'>Photo</text></svg>");
		-webkit-mask-repeat: no-repeat;
		-webkit-mask-size: 100% 100%;
		mask-image: url("data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' width='100%' height='100%'><text font-family='Bebas Neue,Impact,sans-serif' font-size='22vw' fill='white' x='50%' y='55%' text-anchor='middle' dominant-baseline='middle'>Photo</text></svg>");
		mask-repeat: no-repeat;
		mask-size: 100% 100%;
	}

	.vivid-layer img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: contrast(1.05) saturate(0.5) brightness(1.4);
		opacity: 0;
		transition: opacity 1s ease;
	}

	.vivid-layer img:global(.active) {
		opacity: 1;
	}

	.hero-overlay {
		position: absolute;
		inset: 0;
		background:
			radial-gradient(ellipse at center, rgba(5,5,5,0.1) 0%, rgba(5,5,5,0.5) 100%),
			linear-gradient(to bottom, transparent 60%, #050505 100%);
		z-index: 1;
	}

	.title-text {
		position: relative;
		z-index: 4;
		font-family: 'Bebas Neue', Impact, sans-serif;
		font-size: clamp(120px, 22vw, 320px);
		color: transparent;
		line-height: 1;
		letter-spacing: 0.02em;
		opacity: 0;
		animation: titleIn 1.2s cubic-bezier(0.22, 1, 0.36, 1) 0.3s forwards;
	}

	@keyframes titleIn {
		from {
			opacity: 0;
			transform: translateY(40px) scaleY(1.1);
		}
		to {
			opacity: 1;
			transform: translateY(0) scaleY(1);
		}
	}

	/* ---- Hero controls ---- */
	.hero-controls {
		position: absolute;
		bottom: 28px;
		right: 28px;
		z-index: 10;
		display: flex;
		align-items: center;
		gap: 16px;
		opacity: 0;
		animation: cueIn 0.6s ease 1.2s forwards;
	}

	.hero-btn {
		background: none;
		border: none;
		color: rgba(255, 255, 255, 0.3);
		padding: 4px;
		cursor: pointer;
		transition: color 0.4s ease;
	}

	.hero-btn:hover {
		color: rgba(255, 255, 255, 0.85);
	}

	/* ---- Scroll cue ---- */
	.scroll-cue {
		position: absolute;
		bottom: 40px;
		left: 50%;
		transform: translateX(-50%);
		z-index: 10;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 10px;
		opacity: 0;
		animation: cueIn 0.6s ease 1.2s forwards;
		transition: opacity 0.5s;
	}

	.scroll-cue:global(.hidden) {
		opacity: 0 !important;
		pointer-events: none;
	}

	.scroll-cue-text {
		font-size: 9px;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		color: #999;
	}

	.scroll-cue-arrow {
		color: #c8281e;
		animation: bounce 2s ease-in-out infinite;
	}

	@keyframes cueIn {
		to { opacity: 1; }
	}

	@keyframes bounce {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(6px); }
	}

	/* ---- Gallery ---- */
	.gallery {
		max-width: 1400px;
		margin: 0 auto;
		padding: 0 28px;
		columns: 4;
		column-gap: 6px;
	}

	.shot {
		position: relative;
		display: block;
		overflow: hidden;
		cursor: pointer;
		opacity: 0;
		transform: translateY(30px);
		break-inside: avoid;
		margin-bottom: 6px;
		text-decoration: none;
	}

	.shot img {
		width: 100%;
		height: auto;
		display: block;
		filter: contrast(1.15) saturate(0.6) brightness(0.88);
		transition: filter 0.6s ease, transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
	}

	.shot:hover img {
		filter: contrast(1.1) saturate(0.9) brightness(1);
		transform: scale(1.04);
	}

	.shot-num {
		position: absolute;
		bottom: 10px;
		right: 12px;
		font-size: 9px;
		color: rgba(255, 255, 255, 0.25);
		letter-spacing: 0.1em;
		font-weight: 400;
		z-index: 2;
		transition: color 0.3s;
	}

	.shot:hover .shot-num {
		color: rgba(255, 255, 255, 0.5);
	}

	/* Overlay gradient on each shot */
	.shot::after {
		content: "";
		position: absolute;
		inset: 0;
		background: linear-gradient(to top, rgba(5,5,5,0.3) 0%, transparent 40%);
		pointer-events: none;
	}

	/* ---- Footer ---- */
	.foot {
		max-width: 1400px;
		margin: 80px auto 0;
		padding: 20px 28px 32px;
		border-top: 1px solid #151515;
		display: flex;
		justify-content: space-between;
		align-items: center;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		font-size: 10px;
	}

	.foot-left {
		display: flex;
		gap: 20px;
		color: #333;
	}

	.foot-right {
		display: flex;
		align-items: center;
		gap: 12px;
		color: #444;
	}

	.foot-dot {
		width: 3px;
		height: 3px;
		border-radius: 50%;
		background: #c8281e;
	}

	/* ---- Lightbox (CSS :target driven) ---- */
	.lightbox {
		position: fixed;
		inset: 0;
		z-index: 300;
		display: flex;
		align-items: center;
		justify-content: center;
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.3s ease;
	}

	.lightbox:target {
		opacity: 1;
		pointer-events: auto;
	}

	.lightbox-bg {
		position: absolute;
		inset: 0;
		background: rgba(5, 5, 5, 0.96);
		cursor: zoom-out;
	}

	.lightbox-inner {
		position: relative;
		z-index: 1;
		display: flex;
		align-items: center;
		gap: 16px;
		max-width: 94vw;
		max-height: 92vh;
	}

	.lightbox-img {
		max-width: 85vw;
		max-height: 90vh;
		object-fit: contain;
		border-radius: 2px;
	}

	.lightbox-nav {
		color: #666;
		font-size: 48px;
		text-decoration: none;
		line-height: 1;
		padding: 20px 8px;
		transition: color 0.2s;
		user-select: none;
	}

	.lightbox-nav:hover {
		color: #fff;
		text-decoration: none;
	}

	.lightbox-close {
		position: absolute;
		top: 20px;
		right: 28px;
		z-index: 2;
		color: #888;
		font-size: 32px;
		text-decoration: none;
		line-height: 1;
		transition: color 0.3s;
	}

	.lightbox-close:hover {
		color: #fff;
		text-decoration: none;
	}

	/* ---- Responsive ---- */
	@media (max-width: 1100px) {
		.gallery {
			columns: 3;
		}
	}

	@media (max-width: 700px) {
.gallery {
			columns: 2;
			padding: 0 12px;
		}

		.shot {
			margin-bottom: 4px;
		}

		.foot {
			flex-direction: column;
			gap: 12px;
			align-items: flex-start;
			padding: 20px 12px 28px;
		}
	}
</style>

<script>
	// Scroll progress bar
	const progressBar = document.querySelector(".progress-bar") as HTMLElement | null;
	if (progressBar) {
		window.addEventListener("scroll", () => {
			const scrolled = window.scrollY;
			const total = document.documentElement.scrollHeight - window.innerHeight;
			const pct = total > 0 ? (scrolled / total) * 100 : 0;
			progressBar.style.width = `${pct}%`;
		});
	}

	// ---- Hero slideshow ----
	const bgImgs = document.querySelectorAll<HTMLImageElement>(".hero-bg img");
	const vividImgs = document.querySelectorAll<HTMLImageElement>(".vivid-layer img");
	const heroCount = bgImgs.length;
	let heroIdx = 0;
	let paused = false;
	let timer: ReturnType<typeof setInterval>;
	const INTERVAL = 6000;

	function showHero(idx: number) {
		bgImgs.forEach((img, i) => img.classList.toggle("active", i === idx));
		vividImgs.forEach((img, i) => img.classList.toggle("active", i === idx));
	}

	function nextHero() {
		heroIdx = (heroIdx + 1) % heroCount;
		showHero(heroIdx);
	}

	function prevHero() {
		heroIdx = (heroIdx - 1 + heroCount) % heroCount;
		showHero(heroIdx);
	}

	function resetTimer() {
		clearInterval(timer);
		if (!paused) timer = setInterval(nextHero, INTERVAL);
	}

	// Init first image
	showHero(0);
	timer = setInterval(nextHero, INTERVAL);

	const btnPrev = document.getElementById("hero-prev");
	const btnNext = document.getElementById("hero-next");
	const btnPause = document.getElementById("hero-pause");
	const iconPause = btnPause?.querySelector(".icon-pause") as HTMLElement | null;
	const iconPlay = btnPause?.querySelector(".icon-play") as HTMLElement | null;

	btnPrev?.addEventListener("click", () => { prevHero(); resetTimer(); });
	btnNext?.addEventListener("click", () => { nextHero(); resetTimer(); });
	btnPause?.addEventListener("click", () => {
		paused = !paused;
		if (paused) {
			clearInterval(timer);
		} else {
			timer = setInterval(nextHero, INTERVAL);
		}
		if (iconPause) iconPause.style.display = paused ? "none" : "";
		if (iconPlay) iconPlay.style.display = paused ? "" : "none";
	});

	// ---- Gallery ----
	const shots = document.querySelectorAll(".shot");
	const scrollCue = document.querySelector(".scroll-cue");

	const observer = new IntersectionObserver(
		(entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					const el = entry.target as HTMLElement;
					el.style.transition = "opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1), transform 0.8s cubic-bezier(0.22, 1, 0.36, 1)";
					el.style.opacity = "1";
					el.style.transform = "translateY(0)";
					observer.unobserve(el);
				}
			});
		},
		{ threshold: 0.1, rootMargin: "0px 0px -60px 0px" }
	);

	shots.forEach((shot) => observer.observe(shot));

	// Hide scroll cue after scrolling past hero
	let cueHidden = false;
	window.addEventListener("scroll", () => {
		if (!cueHidden && window.scrollY > 100) {
			cueHidden = true;
			scrollCue?.classList.add("hidden");
		}
	});

	// Arrow key + Escape navigation for lightbox
	const totalPhotos = document.querySelectorAll(".lightbox").length;
	document.addEventListener("keydown", (e) => {
		const match = location.hash.match(/^#photo-(\d+)$/);
		if (!match) return;
		const idx = Number.parseInt(match[1], 10);
		if (e.key === "Escape") {
			e.preventDefault();
			location.hash = "#";
		} else if (e.key === "ArrowRight" && idx < totalPhotos - 1) {
			e.preventDefault();
			location.hash = `#photo-${idx + 1}`;
		} else if (e.key === "ArrowLeft" && idx > 0) {
			e.preventDefault();
			location.hash = `#photo-${idx - 1}`;
		}
	});
</script>
