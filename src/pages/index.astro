---
import "@fontsource/instrument-serif/400-italic.css";
import "@fontsource/azeret-mono/400.css";
import Avatar from "../components/Avatar.astro";
import Base from "../layouts/Base.astro";

const year = new Date().getFullYear();
---

<Base title="Janez Rotman" description="MSc Informatics at TUM. Compiler construction, low-level systems, and event photography.">
	<Fragment slot="head">
		<meta name="generator" content={Astro.generator} />
		<meta name="color-scheme" content="light dark" />
		<style is:global>
			@import '../styles/global.css';
		</style>
	</Fragment>
		<header>
			<Avatar />
			<div class="header-text">
				<h1>Janez Rotman</h1>
				<div class="subtitle">MSc Informatics at TUM | Munich</div>
				<nav>
					<a href="mailto:janez@janez.at">janez@janez.at</a>
					<a href="https://github.com/rotmanjanez">GitHub</a>
					<a href="https://linkedin.com/in/janez-rotman">LinkedIn</a>
					<a href="/photo">Photo</a>
				</nav>
			</div>
		</header>

		<main>
			<section>
				<h2>About</h2>
				<p>
					I'm a master's student in informatics at the Technical University
					of Munich, specializing in compiler construction and low-level systems.
					Most of my work involves writing C and C++ for performance-critical code.
					Currently interested in IR design, register allocation algorithms, and how modern CPUs actually execute code.
					On the side, I run a small <a href="/photo">photography business</a>.
				</p>
			</section>

			<section>
				<h2>Research</h2>
				<div class="entry">
					<div class="name">High-Performance Parsing of C23</div>
					<div class="info">
						Bachelor's thesis, 2024 &middot;
						Supervised by Prof. Thomas Neumann, advised by
						<a href="https://aengelke.net">Alexis Engelke</a>
						&middot; 8x faster than Clang by omitting the AST
					</div>
				</div>
			</section>

			<section>
				<h2>Experience</h2>
				<div class="entry">
					<div class="name">Snowflake -Software Engineering Intern</div>
					<div class="info">Apr-Oct 2025 |Berlin</div>
				</div>
				<div class="entry">
					<div class="name">CHECK24 -GenDev IT Scholarship</div>
					<div class="info">2025 |Berlin</div>
				</div>
				<div class="entry">
					<div class="name">TUM -Teaching Assistant &amp; Tutor</div>
					<div class="info">2021-2024 |Computer Architecture</div>
				</div>
				<div class="entry">
					<div class="name">Virtual Vehicle -Research Intern</div>
					<div class="info">2019 &amp; 2020 |Graz</div>
				</div>
			</section>
		</main>

		<footer>
			&copy; {year} Janez Rotman
		</footer>
</Base>

<style>
	body {
		max-width: 600px;
		margin: 0 auto;
		padding: 3rem 1.25rem 4rem;
	}

	header {
		margin-bottom: 2.5rem;
		display: flex;
		align-items: flex-start;
		gap: 1rem;
	}

	.header-text {
		flex: 1 1 auto;
		min-width: 0;
	}

	header h1 {
		font-family: "Instrument Serif", Georgia, serif;
		font-size: 1.8rem;
		font-weight: 400;
		font-style: italic;
		letter-spacing: -0.01em;
		margin-bottom: 0.15rem;
	}

	header .subtitle {
		color: var(--fg-muted);
		font-size: 0.9rem;
		margin-bottom: 0.5rem;
	}

	header nav {
		display: flex;
		flex-wrap: wrap;
		gap: 1.25rem;
		font-size: 0.85rem;
	}

	a {
		color: var(--link);
		text-decoration: none;
	}

	a:hover {
		color: var(--link-hover);
		text-decoration: underline;
	}

	section {
		margin-bottom: 2rem;
	}

	section h2 {
		font-family: "Azeret Mono", monospace;
		font-size: 0.7rem;
		font-weight: 400;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--fg-muted);
		margin-bottom: 0.6rem;
		padding-bottom: 0.3rem;
		border-bottom: 1px solid var(--border);
	}

	section p {
		margin-bottom: 0.5rem;
	}

	.entry {
		margin-bottom: 0.8rem;
	}

	.entry:last-child {
		margin-bottom: 0;
	}

	.entry .name {
		font-weight: 500;
	}

	.entry .info {
		color: var(--fg-muted);
		font-size: 0.88rem;
	}

	footer {
		margin-top: 3rem;
		padding-top: 1rem;
		border-top: 1px solid var(--border);
		color: var(--fg-muted);
		font-size: 0.75rem;
	}

	@media (max-width: 500px) {
		body {
			padding: 2rem 1rem 3rem;
		}
	}
</style>
