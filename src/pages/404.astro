---
import Base from "../layouts/Base.astro";
---

<Base title="404 - Janez Rotman">
	<Fragment slot="head">
		<meta name="color-scheme" content="light dark" />
		<style is:global>
			@import '../styles/global.css';
		</style>
	</Fragment>
		<div class="container">
			<pre class="stacktrace"><code id="trace">Collecting request details...</code></pre>
					<a href="/">back to safety</a>
		</div>

		<script>
			const el = document.getElementById("trace");
			if (el) {
				const { host, pathname, search, protocol } = window.location;
				const url = `${pathname}${search}`;
				const referer = document.referrer || "(none)";
				const dark = window.matchMedia("(prefers-color-scheme: dark)").matches;
				const lines = [
					`${host}: ${url}: Assertion \`status == 200\` failed.`,
					`${host}: GET ${protocol.replace(":", "").toUpperCase()}/1.1 ${url}: 404 Not Found`,
					`${host}: referer: ${referer}`,
					"  ua: " + navigator.userAgent,
					"  viewport: " + window.innerWidth + "x" + window.innerHeight + ", screen: " + screen.width + "x" + screen.height + "@" + devicePixelRatio + "x",
					"  scheme: " + (dark ? "dark" : "light") + ", lang: " + navigator.language,
				];
				el.textContent = lines.join("\n") + "\n";
			}
		</script>
</Base>

<style>
	body {
		max-width: 720px;
		margin: 0 auto;
		padding: 3rem 1.25rem 4rem;
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 100vh;
	}

	.container {
		width: 100%;
		text-align: center;
	}

	.stacktrace {
		text-align: left;
		font-size: 0.88rem;
		line-height: 1.6;
		margin-bottom: 2rem;
		display: inline-block;
		padding: 1.5rem 2rem;
		max-width: 100%;
	}

	.stacktrace code {
		font-size: inherit;
		white-space: pre-wrap;
		word-break: break-all;
	}

	a {
		color: var(--link);
		text-decoration: none;
		font-size: 0.9rem;
	}

	a:hover {
		color: var(--link-hover);
		text-decoration: underline;
	}

	@media (max-width: 500px) {
		body {
			padding: 2rem 1rem 3rem;
		}

		.stacktrace {
			font-size: 0.72rem;
			padding: 1rem 1.25rem;
		}
	}
</style>
