---
interface Props {
	class?: string;
}

const { class: className } = Astro.props;
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" fill="none" class:list={['avatar', className]} style="overflow:visible">
  <rect x="12" y="52" width="40" height="12" fill="#3a3a3a"/>
  <path d="M12 12 L52 12 L52 42 L42 56 L22 56 L12 42 Z" fill="#edcbad"/>
  <rect id="hair-base" x="8" y="8" width="48" height="8" fill="#3a2718" transform="rotate(3 32 12)"/>
  <rect id="hair-top" x="4" y="4" width="56" height="7" fill="#d4b878" transform="rotate(-5 32 7)"/>
  <path id="left-eye" d="M18 32 Q22 28 26 32" stroke="#3a2718" stroke-width="2" fill="none" stroke-linecap="round"/>
  <path id="right-eye" d="M38 32 Q42 28 46 32" stroke="#3a2718" stroke-width="2" fill="none" stroke-linecap="round"/>
  <path id="mouth" d="M28 46 L36 46" stroke="#c49080" stroke-width="1.2" fill="none" stroke-linecap="round"/>
</svg>

<script>
  const BLINK_DURATION = 150;
  const BLINK_MIN_INTERVAL = 2000;
  const BLINK_MAX_EXTRA = 4000;
  const SMILE_DURATION = 800;
  const SMILE_MIN_INTERVAL = 6000;
  const SMILE_MAX_EXTRA = 8000;
  const SMILE_INITIAL_MIN = 3000;
  const SMILE_INITIAL_MAX_EXTRA = 4000;
  const HAIR_MIN_INTERVAL = 5000;
  const HAIR_MAX_EXTRA = 7000;
  const HAIR_INITIAL_MIN = 2000;
  const HAIR_INITIAL_MAX_EXTRA = 3000;

  const MOUTH_STRAIGHT = "M28 46 L36 46";
  const MOUTH_SMILE = "M28 44 Q32 48 36 44";
  const EYE_LEFT_OPEN = "M18 32 Q22 28 26 32";
  const EYE_RIGHT_OPEN = "M38 32 Q42 28 46 32";
  const EYE_LEFT_CLOSED = "M18 32 Q22 33 26 32";
  const EYE_RIGHT_CLOSED = "M38 32 Q42 33 46 32";

  let activeTimeouts = new Set<number>();
  let activeRoot: Element | null = null;

  function clearAvatarState() {
    activeTimeouts.forEach((id) => clearTimeout(id));
    activeTimeouts.clear();
    activeRoot = null;
  }

  function initAvatar() {
    if (activeRoot?.isConnected) return;

    clearAvatarState();

    const root = document.querySelector('svg.avatar');
    const le = document.getElementById('left-eye');
    const re = document.getElementById('right-eye');
    const mo = document.getElementById('mouth');

    if (!root || !le || !re || !mo) return;
    activeRoot = root;

    const schedule = (callback: () => void, delay: number) => {
      const timeoutId = window.setTimeout(() => {
        activeTimeouts.delete(timeoutId);
        callback();
      }, delay);

      activeTimeouts.add(timeoutId);
      return timeoutId;
    };

    function blink() {
      le!.setAttribute('d', EYE_LEFT_CLOSED);
      re!.setAttribute('d', EYE_RIGHT_CLOSED);
      schedule(() => {
        le!.setAttribute('d', EYE_LEFT_OPEN);
        re!.setAttribute('d', EYE_RIGHT_OPEN);
      }, BLINK_DURATION);
    }

    function smile() {
      mo!.setAttribute('d', MOUTH_SMILE);
      schedule(() => {
        mo!.setAttribute('d', MOUTH_STRAIGHT);
      }, SMILE_DURATION);
    }

    function blinkLoop() {
      blink();
      schedule(blinkLoop, BLINK_MIN_INTERVAL + Math.random() * BLINK_MAX_EXTRA);
    }
    schedule(blinkLoop, 0);

    function smileLoop() {
      smile();
      schedule(smileLoop, SMILE_MIN_INTERVAL + Math.random() * SMILE_MAX_EXTRA);
    }
    schedule(smileLoop, SMILE_INITIAL_MIN + Math.random() * SMILE_INITIAL_MAX_EXTRA);

    const hairBase = document.getElementById('hair-base');
    const hairTop = document.getElementById('hair-top');

    if (hairBase && hairTop) {
      hairBase.style.transformOrigin = '32px 12px';
      hairTop.style.transformOrigin = '32px 7px';

      function hairSurprise() {
        hairTop!.animate([
          { transform: 'rotate(-5deg)', offset: 0 },
          { transform: 'rotate(-14deg) translateY(-5px)', offset: 0.15 },
          { transform: 'rotate(6deg) translateY(-6px)', offset: 0.35 },
          { transform: 'rotate(-8deg) translateY(-3px)', offset: 0.55 },
          { transform: 'rotate(-3deg) translateY(-1px)', offset: 0.75 },
          { transform: 'rotate(-5deg)', offset: 1 },
        ], { duration: 700, easing: 'ease-in-out' });

        hairBase!.animate([
          { transform: 'rotate(3deg)', offset: 0 },
          { transform: 'rotate(0deg) translateY(-3px)', offset: 0.15 },
          { transform: 'rotate(-3deg) translateY(-4px)', offset: 0.35 },
          { transform: 'rotate(5deg) translateY(-2px)', offset: 0.55 },
          { transform: 'rotate(2deg) translateY(-1px)', offset: 0.75 },
          { transform: 'rotate(3deg)', offset: 1 },
        ], { duration: 700, easing: 'ease-in-out' });
      }

      function surpriseLoop() {
        hairSurprise();
        schedule(surpriseLoop, HAIR_MIN_INTERVAL + Math.random() * HAIR_MAX_EXTRA);
      }
      schedule(surpriseLoop, HAIR_INITIAL_MIN + Math.random() * HAIR_INITIAL_MAX_EXTRA);
    }

    const cleanup = () => {
      if (activeRoot === root) clearAvatarState();
    };

    document.addEventListener('astro:before-swap', cleanup, { once: true });
    window.addEventListener('pagehide', cleanup, { once: true });
  }

  initAvatar();

  document.addEventListener('astro:page-load', initAvatar);
</script>

<style>
  .avatar {
    width: 5rem;
    height: 5rem;
    background: transparent;
    border: none;
    transform-origin: center bottom;
  }

  .avatar:hover {
    animation: wobble 0.6s ease-in-out;
  }

  @keyframes wobble {
    0%   { transform: rotate(0deg); }
    15%  { transform: rotate(6deg); }
    30%  { transform: rotate(-5deg); }
    45%  { transform: rotate(4deg); }
    60%  { transform: rotate(-3deg); }
    75%  { transform: rotate(2deg); }
    90%  { transform: rotate(-1deg); }
    100% { transform: rotate(0deg); }
  }
</style>
