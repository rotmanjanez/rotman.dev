---
interface Props {
	class?: string;
}

const { class: className } = Astro.props;
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" fill="none" class:list={['avatar', className]} style="overflow:visible">
  <rect x="12" y="52" width="40" height="12" fill="#3a3a3a"/>
  <path d="M12 12 L52 12 L52 42 L42 56 L22 56 L12 42 Z" fill="#edcbad"/>
  <rect id="hair-base" x="8" y="8" width="48" height="8" fill="#3a2718" transform="rotate(3 32 12)"/>
  <rect id="hair-top" x="4" y="4" width="56" height="7" fill="#d4b878" transform="rotate(-5 32 7)"/>
  <path id="left-eye" d="M18 32 Q22 28 26 32" stroke="#3a2718" stroke-width="2" fill="none" stroke-linecap="round"/>
  <path id="right-eye" d="M38 32 Q42 28 46 32" stroke="#3a2718" stroke-width="2" fill="none" stroke-linecap="round"/>
  <line id="mouth" x1="28" y1="46" x2="36" y2="46" stroke="#c49080" stroke-width="1.2" stroke-linecap="round"/>
</svg>

<script>
  const AVATAR_STATE_KEY = '__avatarAnimationState';

  function clearAvatarState() {
    const state = window[AVATAR_STATE_KEY];
    if (!state) return;

    state.timeouts.forEach((timeoutId) => clearTimeout(timeoutId));
    state.timeouts.clear();
    delete window[AVATAR_STATE_KEY];
  }

  function initAvatar() {
    const runningState = window[AVATAR_STATE_KEY];
    if (runningState?.root?.isConnected) return;

    clearAvatarState();

    const root = document.querySelector('svg.avatar');
    const le = document.getElementById('left-eye');
    const re = document.getElementById('right-eye');
    let mo = document.getElementById('mouth');

    if (!root || !le || !re || !mo) return;

    const timeouts = new Set();

    const schedule = (callback, delay) => {
      const timeoutId = window.setTimeout(() => {
        timeouts.delete(timeoutId);
        callback();
      }, delay);

      timeouts.add(timeoutId);
      return timeoutId;
    };

    function blink() {
      le.setAttribute('d', 'M18 32 Q22 33 26 32');
      re.setAttribute('d', 'M38 32 Q42 33 46 32');
      schedule(() => {
        le.setAttribute('d', 'M18 32 Q22 28 26 32');
        re.setAttribute('d', 'M38 32 Q42 28 46 32');
      }, 150);
    }

    function smile() {
      const p = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      p.setAttribute('d', 'M28 44 Q32 48 36 44');
      p.setAttribute('stroke', '#c49080');
      p.setAttribute('stroke-width', '1.2');
      p.setAttribute('fill', 'none');
      p.setAttribute('stroke-linecap', 'round');
      p.setAttribute('id', 'mouth');
      mo.replaceWith(p);
      mo = p;
      schedule(() => {
        const l = document.createElementNS('http://www.w3.org/2000/svg', 'line');
        l.setAttribute('x1', '28');
        l.setAttribute('y1', '46');
        l.setAttribute('x2', '36');
        l.setAttribute('y2', '46');
        l.setAttribute('stroke', '#c49080');
        l.setAttribute('stroke-width', '1.2');
        l.setAttribute('stroke-linecap', 'round');
        l.setAttribute('id', 'mouth');
        mo.replaceWith(l);
        mo = l;
      }, 800);
    }

    function blinkLoop() {
      blink();
      schedule(blinkLoop, 2000 + Math.random() * 4000);
    }
    schedule(blinkLoop, 0);

    function smileLoop() {
      smile();
      schedule(smileLoop, 6000 + Math.random() * 8000);
    }
    schedule(smileLoop, 3000 + Math.random() * 4000);

    const hairBase = document.getElementById('hair-base');
    const hairTop = document.getElementById('hair-top');

    if (hairBase && hairTop) {
      hairBase.style.transformOrigin = '32px 12px';
      hairTop.style.transformOrigin = '32px 7px';

      function hairSurprise() {
        hairTop.animate([
          { transform: 'rotate(-5deg)', offset: 0 },
          { transform: 'rotate(-14deg) translateY(-5px)', offset: 0.15 },
          { transform: 'rotate(6deg) translateY(-6px)', offset: 0.35 },
          { transform: 'rotate(-8deg) translateY(-3px)', offset: 0.55 },
          { transform: 'rotate(-3deg) translateY(-1px)', offset: 0.75 },
          { transform: 'rotate(-5deg)', offset: 1 },
        ], { duration: 700, easing: 'ease-in-out' });

        hairBase.animate([
          { transform: 'rotate(3deg)', offset: 0 },
          { transform: 'rotate(0deg) translateY(-3px)', offset: 0.15 },
          { transform: 'rotate(-3deg) translateY(-4px)', offset: 0.35 },
          { transform: 'rotate(5deg) translateY(-2px)', offset: 0.55 },
          { transform: 'rotate(2deg) translateY(-1px)', offset: 0.75 },
          { transform: 'rotate(3deg)', offset: 1 },
        ], { duration: 700, easing: 'ease-in-out' });
      }

      function surpriseLoop() {
        hairSurprise();
        schedule(surpriseLoop, 5000 + Math.random() * 7000);
      }
      schedule(surpriseLoop, 2000 + Math.random() * 3000);
    }

    const cleanup = () => {
      timeouts.forEach((timeoutId) => clearTimeout(timeoutId));
      timeouts.clear();

      if (window[AVATAR_STATE_KEY]?.root === root) {
        delete window[AVATAR_STATE_KEY];
      }
    };

    window[AVATAR_STATE_KEY] = { root, timeouts, cleanup };
    document.addEventListener('astro:before-swap', cleanup, { once: true });
    window.addEventListener('pagehide', cleanup, { once: true });
  }

  initAvatar();

  document.addEventListener('astro:page-load', initAvatar);
</script>

<style>
  .avatar {
    width: 5rem;
    height: 5rem;
    background: transparent;
    border: none;
    transform-origin: center bottom;
  }

  .avatar:hover {
    animation: wobble 0.6s ease-in-out;
  }

  @keyframes wobble {
    0%   { transform: rotate(0deg); }
    15%  { transform: rotate(6deg); }
    30%  { transform: rotate(-5deg); }
    45%  { transform: rotate(4deg); }
    60%  { transform: rotate(-3deg); }
    75%  { transform: rotate(2deg); }
    90%  { transform: rotate(-1deg); }
    100% { transform: rotate(0deg); }
  }
</style>
